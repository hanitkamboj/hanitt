# LyricForge Backend Configuration

# Server
PORT=3000

# DeepSeek AI
DEEPSEEK_API_KEY=sk-your-key-here

# YouTube OAuth2
YT_CLIENT_ID=your-client-id.apps.googleusercontent.com
YT_CLIENT_SECRET=your-client-secret
YT_REDIRECT_URI=http://localhost:3000/api/youtube/callback
YT_ACCESS_TOKEN=

# Google Drive OAuth2
DRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
DRIVE_CLIENT_SECRET=your-client-secret
DRIVE_REDIRECT_URI=http://localhost:3000/api/drive/callback
DRIVE_ACCESS_TOKEN=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
