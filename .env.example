# LyricForge — Client-Side Environment
# Copy this to .env and fill in your keys
# (These are also configurable via the Settings modal in the app)

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# DeepSeek AI
VITE_DEEPSEEK_API_KEY=sk-your-key-here

# YouTube
VITE_YT_API_KEY=AIza...
VITE_YT_CLIENT_ID=...apps.googleusercontent.com

# Google Drive
VITE_DRIVE_FOLDER_ID=folder-id

# Backend Server
VITE_SERVER_URL=http://localhost:3000
